# The AI layer needs Anthropic credentials. Options, in priority order:
#   1. Export ANTHROPIC_API_KEY (API key).
#   2. Use OAuth: `ant auth login`, then `eval "$(ant auth print-credentials --env)"`
#      to export ANTHROPIC_AUTH_TOKEN (no static key needed).
#   3. Let `hc` prompt you interactively — it can save a key to
#      ~/.ln-health/credentials (chmod 600) for next time.
#   4. Run with --no-ai to skip the AI layer entirely (probes still run).
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_AUTH_TOKEN=      # OAuth bearer token (alternative to an API key)

# --- GitHub Models provider (alternative backend; not Claude) ---
# Use with:  hc check . --provider github-models
# GITHUB_TOKEN=github_pat_...        # fine-grained PAT with the "models" permission
# HC_GITHUB_MODEL=openai/gpt-4o-mini
# HC_GITHUB_MODELS_URL=https://models.github.ai/inference

# --- Gemini provider (alternative backend; not Claude; free tier, POC-friendly) ---
# Use with:  hc check . --provider gemini
# GEMINI_API_KEY=AIza...             # from Google AI Studio (personal account works)
# HC_GEMINI_MODEL=gemini-2.5-flash
# HC_GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Optional overrides (Anthropic)
# HC_MODEL=claude-opus-4-8
# HC_EFFORT=high
