{
  "name": "crystal-pulse",
  "version": "0.2.0",
  "description": "Crystal Pulse — AI-assisted health-check multitool for React, Angular and Node.js codebases.",
  "type": "module",
  "bin": {
    "crystal-pulse": "dist/index.js",
    "pulse": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "ui": "tsx src/index.ts ui",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "health-check",
    "ai",
    "react",
    "angular",
    "nodejs"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.0",
    "@clack/prompts": "^0.7.0",
    "cfonts": "^3.3.1",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
